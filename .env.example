# ====================================================================
# OEM Content Factory — Environment Variables
# Copy เป็น .env (local) หรือใส่ใน Vercel Dashboard → Project → Settings → Environment Variables
# ====================================================================

# ====== Server (Local dev only) ======
PORT=3000
PUBLIC_URL=http://localhost:3000

# ====== Supabase ======
# 1. สร้าง project ฟรีที่ https://supabase.com
# 2. SQL Editor → run backend/scripts/schema.sql
# 3. Settings → API → copy URL + service_role key
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ====== Auth ======
JWT_SECRET=please-change-to-long-random-string
ADMIN_EMAIL=admin@oemcontent.co
ADMIN_PASSWORD=ChangeMe123!

# ====== OpenRouter (AI: text + image ผ่าน key เดียว) ======
# 1. สมัครที่ https://openrouter.ai → Keys → Create Key
# 2. เติมเครดิตเริ่มต้น $5 ก็ใช้ได้นาน
OPENROUTER_API_KEY=

# Model สำหรับ text generation (default: claude haiku 4.5)
# ทางเลือก: anthropic/claude-sonnet-4.5, openai/gpt-4o-mini, google/gemini-2.5-flash
OPENROUTER_TEXT_MODEL=anthropic/claude-haiku-4.5

# Model สำหรับ image generation (ผ่าน OpenRouter /chat/completions)
# ✅ ทางเลือก:
#   openai/gpt-5.4-image-2                 ← default ($0.98/ภาพ — สวยสุด, Thai text ดี, ต้อง credit ≥ $1)
#   google/gemini-3.1-flash-image-preview  ← fallback ($0.04/ภาพ — ราคาถูก, Thai text เพี้ยน)
#   google/gemini-2.5-flash-image          ← ผ่าน Google AI direct (ต้องตั้ง GOOGLE_AI_API_KEY)
#   openai/gpt-image-1                     ← ผ่าน OpenAI direct (ต้องตั้ง OPENAI_API_KEY)
# ⚠️ GPT-5.4-image-2 ใช้ async path เท่านั้น (Edge Function) — sync endpoint จะ timeout บน Vercel
OPENROUTER_IMAGE_MODEL=openai/gpt-5.4-image-2

# 🚫 ปิด auto-fallback ไป Gemini เมื่อ primary model fail (default: เปิด fallback)
# ตั้ง =1 ถ้าอยาก fail ชัดๆ แทนการได้ภาพคุณภาพต่ำกว่า
IMAGE_DISABLE_FALLBACK=

# Force routing — ปกติ auto-detect ตาม model + key ที่มี
# IMAGE_PROVIDER=openrouter | openai | google | auto (default)

# Optional: bake hint เข้า prompt
OPENROUTER_IMAGE_QUALITY=medium    # low | medium | high — แค่ใส่ใน prompt hint
OPENROUTER_IMAGE_SIZE=1024x1024    # 1024x1024 | 1024x1536 | 1536x1024 — แค่ใส่ใน prompt hint

# ====== Optional: Direct provider keys (bypass OpenRouter proxy) ======
# OPENAI_API_KEY=sk-...        # สำหรับ openai/gpt-image-1, openai/dall-e-3
# GOOGLE_AI_API_KEY=...        # สำหรับ google/gemini-*-image (Thai text สวยกว่า)

# ====== Async image worker ======
# Vercel /api/ai/image-async จะ trigger worker ตามลำดับนี้:
#   1. RENDER_WORKER_URL (ถ้าตั้ง) — ไม่จำกัด wall-clock, รองรับ GPT-5.4 100% (แนะนำ)
#   2. SUPABASE_EDGE_URL (fallback) — wall-clock 150s, GPT-5.4 มักไม่ทัน

# 🥇 Render worker (แนะนำสำหรับ GPT-5.4 — ฟรี, ไม่จำกัดเวลา)
# ดู worker-render/README.md
RENDER_WORKER_URL=             # https://<service>.onrender.com/process-image-job

# 🥈 Supabase Edge Function (fallback — รองรับ Gemini/gpt-image แต่ GPT-5.4 ไม่ทัน 150s)
# ดู supabase/functions/image-worker/README.md
SUPABASE_EDGE_URL=             # https://<project>.supabase.co/functions/v1/image-worker

# Shared auth — ต้องเหมือนกันใน Render env, Supabase Edge secrets, และ Vercel env
WORKER_SECRET=                 # random token (e.g., openssl rand -hex 32)

# ====== Facebook Auto-Post ======
# 1. ไป https://developers.facebook.com → Create App (Business)
# 2. Graph API Explorer → ขอ permission: pages_manage_posts, pages_read_engagement, pages_show_list
# 3. Generate User Token → ใช้ /api/facebook/exchange-token แลกเป็น Page Token
FB_APP_ID=
FB_APP_SECRET=
FB_PAGE_ID=
FB_PAGE_TOKEN=

# ====== Optional: n8n webhook (ถ้าอยากใช้ n8n สำหรับ multi-platform) ======
N8N_WEBHOOK_URL=

# ====== Azure Speech (Thai TTS for Video Reels) ======
# 1. portal.azure.com → Create resource → "Speech service" (free tier F0)
# 2. Region: เลือก Southeast Asia (latency ต่ำสุดสำหรับไทย)
# 3. Keys and Endpoint → copy KEY 1
# Free tier: 500K chars/month TTS — เพียงพอสำหรับ ~5000 Reels/เดือน
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=southeastasia

# ====== Pexels Video API (Stock bg videos สำหรับ Talking Avatar multi-scene) ======
# ฟรี · 200 requests/hour
# 1. สมัครฟรีที่ https://www.pexels.com/api/
# 2. ขอ API key ในหน้า dashboard (ไม่ต้อง deposit)
# 3. copy → ใส่ตรงนี้และใน Vercel env
# ใช้ตอน user เลือก bg = 'pexels' ใน Talking Avatar — auto fetch real animal/food/scene videos
PEXELS_API_KEY=

# ====== fal.ai (Lip-sync mascot video for Video Reels) ======
# ใช้ตอน Reel ที่มี mascot พูดได้ (SadTalker/Hallo)
# 1. สมัครฟรีที่ https://fal.ai → Dashboard → Keys → Create new key
# 2. copy ค่า → ใส่ตรงนี้และใน Vercel + Render env
# ราคา: SadTalker ~$0.05/clip (5-10s) · Hallo ~$0.10/clip
# Free trial credits: ~$1 = ~20 clips
# ⚠️ ตั้งใน worker-render (Render.com) ด้วย — ตัว worker เป็นคนเรียก fal.ai จริง
FAL_KEY=

# ====== Gemini Veo (Pick a Card → วิดีโอ cinematic จริง) ======
# ใช้ปุ่ม "🎬 สร้างวิดีโอด้วย Gemini Veo" ในแท็บ Pick a Card
# ⚠️ ต้องเป็น Gemini API key แบบเสียเงิน (paid tier) ที่เปิดสิทธิ์ Veo แล้ว
#    ราคาประมาณ $3–4 ต่อคลิป ~8 วินาที
# ใช้ตัวแปร GOOGLE_AI_API_KEY เดียวกับ image gen (ด้านบน)
# VEO_MODEL — ปล่อยว่างได้ จะใช้ค่า default veo-3.0-fast-generate-001
VEO_MODEL=veo-3.0-fast-generate-001

# ====== ถอดเสียง (Talking Avatar → "ถอดจากเสียง") ======
# /ai/transcribe ลองตามลำดับ: Google AI (Gemini) direct → OpenRouter
# - Google: ใช้ GOOGLE_AI_API_KEY เดียวกับ image gen (free tier) — ลองก่อน
# - OpenRouter: ใช้ OPENROUTER_API_KEY (ด้านบน) เป็น fallback อัตโนมัติ
#   ⭐ OpenRouter ใช้เครดิตของ OpenRouter เอง → ทำงานได้แม้โควต้า Google หมด
#   OpenRouter ไม่มี endpoint Whisper แยก — ส่ง audio ให้ multimodal chat model
#   (Gemini / GPT-4o-audio) ผ่าน input_audio part แทน
# GEMINI_TRANSCRIBE_MODEL — ปล่อยว่างได้ (default gemini-2.0-flash ฯลฯ)
# OPENROUTER_TRANSCRIBE_MODEL — default google/gemini-2.0-flash-001
#   ถ้า provider ไม่รับ audio ลองเปลี่ยนเป็น openai/gpt-4o-audio-preview
# GEMINI_TRANSCRIBE_MODEL=
# OPENROUTER_TRANSCRIBE_MODEL=google/gemini-2.0-flash-001

# ====== Optional: CORS ======
CORS_ORIGIN=*

# ====== Khurutheph integration (GURU course → โพสบทความขึ้นเว็บคุรุเทพ) ======
KHURUTHEPH_API_URL=https://khurutheph.com
KHURUTHEPH_ARTICLES_KEY=
